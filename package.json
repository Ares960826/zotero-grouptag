{
  "name": "zotero-grouptag",
  "version": "1.0.1",
  "description": "A Zotero plugin for Chrome style visual grouping of PDF reader tabs",
  "type": "module",
  "config": {
    "addonName": "Zotero GroupTag",
    "addonID": "grouptag@zotero.org",
    "addonRef": "grouptag",
    "addonInstance": "GroupTag",
    "prefsPrefix": "extensions.zotero.grouptag"
  },
  "zotero-plugin": {
    "name": "Zotero GroupTag",
    "id": "grouptag@zotero.org",
    "namespace": "grouptag",
    "xpiName": "zotero-grouptag",
    "updateURL": "https://github.com/ares/zotero-grouptag/releases/download/release/update.json",
    "xpiDownloadLink": "https://github.com/ares/zotero-grouptag/releases/download/v{{version}}/{{xpiName}}.xpi",
    "source": [
      "src",
      "addon"
    ]
  },
  "main": "src/index.ts",
  "scripts": {
    "start": "zotero-plugin serve",
    "build": "zotero-plugin build && tsc --noEmit",
    "lint:check": "prettier --check . && eslint .",
    "lint:fix": "prettier --write . && eslint . --fix",
    "release": "zotero-plugin release",
    "test": "zotero-plugin test",
    "update-deps": "npm update --save"
  },
  "keywords": [
    "zotero",
    "plugin",
    "tabs",
    "grouping",
    "pdf",
    "reader"
  ],
  "author": "zotero-grouptag contributors",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/ares/zotero-grouptag.git"
  },
  "bugs": {
    "url": "https://github.com/ares/zotero-grouptag/issues"
  },
  "homepage": "https://github.com/ares/zotero-grouptag#readme",
  "dependencies": {
    "zotero-plugin-toolkit": "^5.1.0-beta.13"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.10.0",
    "@zotero-plugin/eslint-config": "^0.6.7",
    "chai": "^6.2.1",
    "eslint": "^9.39.2",
    "mocha": "^11.7.5",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "zotero-plugin-scaffold": "^0.8.2",
    "zotero-types": "^4.1.0-beta.4"
  },
  "prettier": {
    "printWidth": 80,
    "tabWidth": 2,
    "endOfLine": "lf",
    "overrides": [
      {
        "files": [
          "*.xhtml"
        ],
        "options": {
          "htmlWhitespaceSensitivity": "css"
        }
      }
    ]
  }
}
